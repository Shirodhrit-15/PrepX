rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {

    // Profile pictures: user can read/write their own
    match /profile_pictures/{uid}.jpg {
      allow read: if request.auth != null;
      allow write: if request.auth != null
                   && request.auth.uid == uid
                   && request.resource.size < 2 * 1024 * 1024   // max 2 MB
                   && request.resource.contentType.matches('image/.*');
    }

    // Resumes: user can read/write their own folder
    match /resumes/{uid}/{fileName} {
      allow read: if request.auth != null && request.auth.uid == uid;
      allow write: if request.auth != null
                   && request.auth.uid == uid
                   && request.resource.size < 10 * 1024 * 1024  // max 10 MB
                   && request.resource.contentType == 'application/pdf';
    }
  }
}
